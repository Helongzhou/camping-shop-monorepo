# Copy to .env at repo root (and packages/db/.env for Prisma CLI)
# cp .env.example .env

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myshop?schema=public"

# NestJS API (apps/api)
PORT=3001
NODE_ENV=development

# Next.js storefront (apps/web)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Stripe (add when integrating checkout)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
