{
  "name": "my-shop-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "My Shop indie storefront monorepo (Next.js + NestJS)",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"@myshop/*\" dev",
    "dev:apps": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm --filter @myshop/shared --filter @myshop/db run build && pnpm --parallel --filter \"./apps/*\" build",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @myshop/db db:migrate",
    "db:generate": "pnpm --filter @myshop/db db:generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module"
}
